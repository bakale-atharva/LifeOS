generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id            String   @id @default("user-1")
  level         Int      @default(1)
  overallScore  Int      @default(0)
  gold          Int      @default(0)
  
  // Scores (0-100)
  goalsScore    Int      @default(0)
  timeScore     Int      @default(0)
  healthScore   Int      @default(0)
  relationScore Int      @default(0)
  financeScore  Int      @default(0)

  lastCalculated DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Quest {
  id          String   @id @default(cuid())
  title       String
  description String?  // The "Lore" / Why
  type        String   @default("SIDE") // SIDE or BOSS
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, FAILED
  difficulty  Int      @default(1) // 1-5
  
  // GPS Framework Fields
  antiGoals   String?  // [G] Curses/Boundaries
  milestones  Json?    // [P] Plan: Array of { title, completed }
  preMortem   String?  // [P] Anticipated failures and solutions
  dailyAction String?  // [S] The recurring attack
  
  totalHp     Int      @default(100)
  currentHp   Int      @default(100)
  
  deadline    DateTime?
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

model FocusSession {
  id        String   @id @default(cuid())
  duration  Int      // in minutes
  startTime DateTime @default(now())
  endTime   DateTime?
  status    String   @default("COMPLETED") // COMPLETED, ABANDONED
  goldEarned Int     @default(0)
}

model HealthLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  type      String   // SLEEP, WATER, WORKOUT, DIET
  value     Float    // e.g., hours of sleep, liters of water
  createdAt DateTime @default(now())
}

model Relationship {
  id             String   @id @default(cuid())
  name           String
  bondLevel      Int      @default(0)
  lastInteraction DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // INCOME, EXPENSE
  category    String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}
